<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSS'Z',UTC}","level":"%level","service":"scheduler-service","traceId":"%X{traceId:-}","spanId":"%X{spanId:-}","executionPublicId":"%X{executionPublicId:-}","workflowRunPublicId":"%X{workflowRunPublicId:-}","workerId":"%X{workerId:-}","message":"%replace(%msg){'"', '\\"'}","logger":"%logger","thread":"%thread"}%n</pattern>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
