# FlowForge Local Development Environment Variables Template
#
# Sourcing this file is NOT required to run automated Maven tests via `./mvnw clean verify`
# (which utilize dynamic Testcontainers coordinates).
# Sourcing is only required for manual local service startup.

# PostgreSQL Configuration
export FLOWFORGE_DB_URL=jdbc:postgresql://localhost:5432/flowforge
export FLOWFORGE_DB_USERNAME=postgres
export FLOWFORGE_DB_PASSWORD=local_dev_password_change_me

# Kafka (Redpanda) Configuration
export FLOWFORGE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Valkey (Redis-compatible) Configuration
export FLOWFORGE_VALKEY_HOST=localhost
export FLOWFORGE_VALKEY_PORT=6379
